{
  "info": {
    "name": "Salas e Reservas API",
    "_postman_id": "2f3e879d-7dd4-4d62-b9d7-rooms-reservations",
    "description": "Collection manual para validar endpoints de salas e reservas: sucesso, validacao e sem permissao.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "adminEmail", "value": "admin{{$timestamp}}@teste.com" },
    { "key": "userEmail", "value": "user{{$timestamp}}@teste.com" },
    { "key": "otherUserEmail", "value": "other{{$timestamp}}@teste.com" },
    { "key": "password", "value": "123456" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "otherUserToken", "value": "" },
    { "key": "roomName", "value": "" },
    { "key": "roomId", "value": "" },
    { "key": "reservationId", "value": "" },
    { "key": "ownerCancelReservationId", "value": "" },
    { "key": "otherReservationId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register admin - sucesso",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Teste\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"ADMIN\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register user - sucesso",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Teste\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"USER\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userToken', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register other user - sucesso",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Outro Usuario\",\n  \"email\": \"{{otherUserEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"USER\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('otherUserToken', json.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
